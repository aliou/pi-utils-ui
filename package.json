{
  "name": "@aliou/pi-utils-ui",
  "version": "0.4.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Shared TUI abstractions for Pi extensions",
  "exports": {
    ".": "./src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aliou/pi-utils-ui"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "dev:showcase": "tsx showcase/index.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm changeset publish"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0 <1",
    "@earendil-works/pi-tui": ">=0.74.0 <1"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aliou/biome-plugins": "^0.4.0",
    "@biomejs/biome": "^2.4.3",
    "@changesets/cli": "^2.27.11",
    "@earendil-works/pi-coding-agent": "0.74.0",
    "@earendil-works/pi-tui": "0.74.0",
    "@types/node": "^25.0.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.26.1"
}
